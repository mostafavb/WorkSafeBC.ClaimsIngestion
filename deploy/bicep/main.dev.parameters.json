{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "dev"
    },
    "location": {
      "value": "canadacentral"
    },
    "prefix": {
      "value": "wsbcclaims"
    },
    "workerImage": {
      "value": "ghcr.io/mostafavb/worksafebc-claims-ingestion-worker:dev"
    },
    "claimsContainerName": {
      "value": "claims-inbox"
    },
    "claimTopicName": {
      "value": "claims-ingestion"
    },
    "claimSubscriptionName": {
      "value": "claims-worker"
    },
    "sqlAdministratorLogin": {
      "value": "sqladminuser"
    },
    "sqlAdministratorPassword": {
      "value": "<<replace-with-dev-secret>>"
    }
  }
}
